<Activity mc:Ignorable="sap sap2010" x:Class="TC_DuplicateNameValidation"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    <x:Property Name="in_Username" Type="InArgument(x:String)" />
    <x:Property Name="in_Password" Type="InArgument(x:String)" />
    <x:Property Name="in_CustomerKey" Type="InArgument(x:String)" />
    <x:Property Name="in_QATestSeriesRoute" Type="InArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportReferences>
        <mva:VisualBasicImportReference Import="System" Assembly="mscorlib" />
        <mva:VisualBasicImportReference Import="UiPath.Core" Assembly="UiPath.Core" />
        <mva:VisualBasicImportReference Import="UiPath.Core.Activities" Assembly="UiPath.Core.Activities" />
      </mva:VisualBasicSettings.ImportReferences>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>
  <Sequence DisplayName="TC: Try Creating QA Test Series with Duplicate Name" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_DuplicateName" />
      <Variable x:TypeArguments="x:String" Name="var_SuccessMessage" />
      <Variable x:TypeArguments="x:String" Name="var_ValidationMsg" />
    </Sequence.Variables>

    <!-- Login -->
    <InvokeWorkflowFile DisplayName="Login to Application" WorkflowFileName="Workflows\Common\Login.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_1">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[in_BaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_Username">[in_Username]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_Password">[in_Password]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_CustomerKey">[in_CustomerKey]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Navigate to QA Test Series -->
    <InvokeWorkflowFile DisplayName="Navigate to QA Test Series" WorkflowFileName="Workflows\Common\NavigateToQATestSeries.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_2">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Route">[in_QATestSeriesRoute]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Generate unique name for first creation -->
    <Assign DisplayName="Generate Duplicate Test Name" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[var_DuplicateName]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">["Duplicate Test " &amp; DateTime.Now.Ticks.ToString()]</InArgument>
      </Assign.Value>
    </Assign>

    <!-- STEP 1: Create first test series -->
    <InvokeWorkflowFile DisplayName="Click Add Button (First)" WorkflowFileName="Workflows\PageActions\ClickAddButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_3" />

    <InvokeWorkflowFile DisplayName="Fill Fields - First Creation" WorkflowFileName="Workflows\PageActions\FillMandatoryFields.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_4">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Name">[var_DuplicateName]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_BusinessUnit">18821</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_LawRegulation">895</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <InvokeWorkflowFile DisplayName="Click Save (First)" WorkflowFileName="Workflows\PageActions\ClickSaveButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_5" />

    <InvokeWorkflowFile DisplayName="Verify Success (First)" WorkflowFileName="Workflows\Verification\VerifySuccessToast.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_6">
      <InvokeWorkflowFile.Arguments>
        <OutArgument x:TypeArguments="x:String" x:Key="out_MessageText">[var_SuccessMessage]</OutArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- STEP 2: Navigate back and open Add form again -->
    <InvokeWorkflowFile DisplayName="Navigate Back to QA Test Series" WorkflowFileName="Workflows\Common\NavigateToQATestSeries.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_7">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Route">[in_QATestSeriesRoute]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <InvokeWorkflowFile DisplayName="Click Add Button (Second)" WorkflowFileName="Workflows\PageActions\ClickAddButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_8" />

    <!-- STEP 3: Attempt duplicate creation -->
    <InvokeWorkflowFile DisplayName="Fill Fields - Duplicate Attempt" WorkflowFileName="Workflows\PageActions\FillMandatoryFields.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_9">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Name">[var_DuplicateName]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_BusinessUnit">18821</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_LawRegulation">895</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <InvokeWorkflowFile DisplayName="Click Save (Duplicate)" WorkflowFileName="Workflows\PageActions\ClickSaveButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_10" />

    <!-- STEP 4: Verify validation error for duplicate -->
    <InvokeWorkflowFile DisplayName="Verify Validation Toast" WorkflowFileName="Workflows\Verification\VerifyValidationToast.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_11" />

    <InvokeWorkflowFile DisplayName="Get Validation Message" WorkflowFileName="Workflows\Verification\GetValidationMessage.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_12">
      <InvokeWorkflowFile.Arguments>
        <OutArgument x:TypeArguments="x:String" x:Key="out_MessageText">[var_ValidationMsg]</OutArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Assert validation message is not empty -->
    <If Condition="[String.IsNullOrEmpty(var_ValidationMsg)]" DisplayName="Assert Validation Message Not Empty" sap2010:WorkflowViewState.IdRef="If_1">
      <If.Then>
        <Throw DisplayName="Throw - Empty Validation Message" Exception="[New System.Exception(&quot;Expected validation message for duplicate name but got empty string&quot;)]" sap2010:WorkflowViewState.IdRef="Throw_1" />
      </If.Then>
    </If>

    <WriteLine DisplayName="Log Success" Text="[&quot;TC PASSED: Duplicate validation message received: &quot; &amp; var_ValidationMsg]" sap2010:WorkflowViewState.IdRef="WriteLine_1" />

  </Sequence>
</Activity>
