<Activity mc:Ignorable="sap sap2010" x:Class="TC_BusinessUnitValidation"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="in_BaseURL" Type="InArgument(x:String)" />
    <x:Property Name="in_Username" Type="InArgument(x:String)" />
    <x:Property Name="in_Password" Type="InArgument(x:String)" />
    <x:Property Name="in_CustomerKey" Type="InArgument(x:String)" />
    <x:Property Name="in_QATestSeriesRoute" Type="InArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportReferences>
        <mva:VisualBasicImportReference Import="System" Assembly="mscorlib" />
        <mva:VisualBasicImportReference Import="UiPath.Core" Assembly="UiPath.Core" />
        <mva:VisualBasicImportReference Import="UiPath.Core.Activities" Assembly="UiPath.Core.Activities" />
      </mva:VisualBasicSettings.ImportReferences>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>
  <Sequence DisplayName="TC: Verify Business Unit(s) Mandatory Validation" sap2010:WorkflowViewState.IdRef="Sequence_1">

    <!-- Step 1: Login to Application -->
    <InvokeWorkflowFile DisplayName="Login to Application" WorkflowFileName="Workflows\Common\Login.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_1">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BaseURL">[in_BaseURL]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_Username">[in_Username]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_Password">[in_Password]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_CustomerKey">[in_CustomerKey]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Step 2: Navigate to QA Test Series page -->
    <InvokeWorkflowFile DisplayName="Navigate to QA Test Series" WorkflowFileName="Workflows\Common\NavigateToQATestSeries.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_2">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Route">[in_QATestSeriesRoute]</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Step 3: Click Add Button to open form -->
    <InvokeWorkflowFile DisplayName="Click Add Button" WorkflowFileName="Workflows\PageActions\ClickAddButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_3" />

    <!-- Step 4: Verify Business Unit(s) has mandatory asterisk -->
    <InvokeWorkflowFile DisplayName="Verify Business Unit Mandatory Asterisk" WorkflowFileName="Workflows\Verification\VerifyMandatoryFieldAsterisk.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_4">
      <InvokeWorkflowFile.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_FieldName">Business Unit(s)</InArgument>
      </InvokeWorkflowFile.Arguments>
    </InvokeWorkflowFile>

    <!-- Step 5: Click Save without filling fields to trigger validation -->
    <InvokeWorkflowFile DisplayName="Click Save Button" WorkflowFileName="Workflows\PageActions\ClickSaveButton.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_5" />

    <!-- Step 6: Take screenshot of validation state -->
    <ui:TakeScreenshot DisplayName="Screenshot - Business Unit Validation" OutputPath="test-results\business-unit-validation.png" sap2010:WorkflowViewState.IdRef="TakeScreenshot_1">
      <ui:TakeScreenshot.Target>
        <ui:Target Selector="&lt;html app='chrome' /&gt;" TimeoutMS="5000" />
      </ui:TakeScreenshot.Target>
    </ui:TakeScreenshot>

    <!-- Step 7: Verify validation toast appears -->
    <InvokeWorkflowFile DisplayName="Verify Validation Toast" WorkflowFileName="Workflows\Verification\VerifyValidationToast.xaml" sap2010:WorkflowViewState.IdRef="InvokeWorkflowFile_6" />

    <WriteLine DisplayName="Log Success" Text="TC PASSED: Business Unit mandatory field validation verified" sap2010:WorkflowViewState.IdRef="WriteLine_1" />

  </Sequence>
</Activity>
