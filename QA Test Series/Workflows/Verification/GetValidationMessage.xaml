<Activity mc:Ignorable="sap sap2010" x:Class="GetValidationMessage"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="out_MessageText" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportReferences>
        <mva:VisualBasicImportReference Import="System" Assembly="mscorlib" />
        <mva:VisualBasicImportReference Import="UiPath.Core" Assembly="UiPath.Core" />
        <mva:VisualBasicImportReference Import="UiPath.Core.Activities" Assembly="UiPath.Core.Activities" />
      </mva:VisualBasicSettings.ImportReferences>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>
  <Sequence DisplayName="Get Validation Message Text" sap2010:WorkflowViewState.IdRef="Sequence_1">

    <!-- Wait for toast message to be visible -->
    <ui:ElementExists DisplayName="Wait for Toast Message Element" Result="{x:Null}" sap2010:WorkflowViewState.IdRef="ElementExists_1">
      <ui:ElementExists.Target>
        <ui:Target Selector="&lt;html app='chrome' /&gt;&lt;webctrl css-selector='.toast-message' /&gt;" TimeoutMS="10000" />
      </ui:ElementExists.Target>
    </ui:ElementExists>

    <!-- Get the validation message text content -->
    <ui:GetText DisplayName="Get Validation Message Text" Value="[out_MessageText]" sap2010:WorkflowViewState.IdRef="GetText_1">
      <ui:GetText.Target>
        <ui:Target Selector="&lt;html app='chrome' /&gt;&lt;webctrl css-selector='.toast-message' /&gt;" TimeoutMS="10000" />
      </ui:GetText.Target>
    </ui:GetText>

    <!-- Trim the result -->
    <Assign DisplayName="Trim Message Text" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[out_MessageText]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(out_MessageText IsNot Nothing, out_MessageText.Trim(), "")]</InArgument>
      </Assign.Value>
    </Assign>

  </Sequence>
</Activity>
