<Activity mc:Ignorable="sap sap2010" x:Class="VerifySuccessToast"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="out_MessageText" Type="OutArgument(x:String)" />
    <x:Property Name="out_IsVisible" Type="OutArgument(x:Boolean)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <mva:VisualBasicSettings>
      <mva:VisualBasicSettings.ImportReferences>
        <mva:VisualBasicImportReference Import="System" Assembly="mscorlib" />
        <mva:VisualBasicImportReference Import="UiPath.Core" Assembly="UiPath.Core" />
        <mva:VisualBasicImportReference Import="UiPath.Core.Activities" Assembly="UiPath.Core.Activities" />
      </mva:VisualBasicSettings.ImportReferences>
    </mva:VisualBasicSettings>
  </mva:VisualBasic.Settings>
  <Sequence DisplayName="Verify Success Toast Appears" sap2010:WorkflowViewState.IdRef="Sequence_1">

    <!-- Check if success toast (.toast-success) is visible -->
    <ui:ElementExists DisplayName="Check Success Toast Visible" Result="[out_IsVisible]" sap2010:WorkflowViewState.IdRef="ElementExists_1">
      <ui:ElementExists.Target>
        <ui:Target Selector="&lt;html app='chrome' /&gt;&lt;webctrl css-selector='.toast-success' /&gt;" TimeoutMS="10000" />
      </ui:ElementExists.Target>
    </ui:ElementExists>

    <!-- Throw if toast not visible -->
    <If Condition="[Not out_IsVisible]" DisplayName="Assert Success Toast Visible" sap2010:WorkflowViewState.IdRef="If_1">
      <If.Then>
        <Throw DisplayName="Throw - Success Toast Not Found" Exception="[New System.Exception(&quot;Success toast notification did not appear within 10 seconds&quot;)]" sap2010:WorkflowViewState.IdRef="Throw_1" />
      </If.Then>
    </If>

    <!-- Get the success message text -->
    <ui:GetText DisplayName="Get Success Toast Message Text" Value="[out_MessageText]" sap2010:WorkflowViewState.IdRef="GetText_1">
      <ui:GetText.Target>
        <ui:Target Selector="&lt;html app='chrome' /&gt;&lt;webctrl css-selector='.toast-success' /&gt;" TimeoutMS="5000" />
      </ui:GetText.Target>
    </ui:GetText>

  </Sequence>
</Activity>
