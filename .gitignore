################################################################################
# UiPath Studio .gitignore
# Prevents auto-generated, cache, and local artifacts from being committed
################################################################################

# Local cache, compiled DLLs, NuGet cache, workflow outlines, autopilot skills
.local/

# Object Repository - auto-generated UI element definitions
.objects/

# Debug/Design/Release settings - local user-specific configuration
.settings/

# Project design metadata
.project/

# Test Manager Hub config
.tmh/

# Informative screenshots - design-time visual previews only (not needed for execution)
.screenshots/

# Temp files
*.ps1
git_*.txt

################################################################################
# WHAT IS COMMITTED (essential project files):
#   .gitignore          — Git configuration
#   project.json        — UiPath project definition
#   project.uiproj      — UiPath project file
#   entry-points.json   — Workflow entry points
#   *.xaml              — Workflow definitions
#   *.xaml.json         — Workflow designer metadata
#   .storage/           — UI element ancestry & target data (REQUIRED for Click/Type)
################################################################################

################################################################################
# Added by UiPath Studio
# Prevent caching and local artifacts from being committed
################################################################################
.local
################################################################################
# End of UiPath Studio common ignores
################################################################################
